              "handlesGoodsOrServices": false,
              "isWebApplication": false,
              "privilegeLevel": "",
              "threats": [
                {
                  "id": "29c73ec6-5201-4e09-a71a-849418dc40a1",
                  "title": "Rogue AP / Evil Twin",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Spoofing",
                  "description": "Attacker sets up a fake AP mimicking the real one to intercept user traffic",
                  "mitigation": "Deploy Wireless IDS to detect unauthorised APs, enable mutual authentication",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 7,
                  "score": ""
                },
                {
                  "id": "695ea120-62ff-4aab-bfd9-4a8267d3f506",
                  "title": "DoS / Deauthentication Attack",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Denial of service",
                  "description": "Attacker floods the AP with deauth frames, denying service to legitimate users",
                  "mitigation": "Enable 802.11w Management Frame Protection",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 8,
                  "score": ""
                },
                {
                  "id": "f3857edb-b892-4a35-a708-5822fb11d3f8",
                  "title": "Traffic Tampering / MITM",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Tampering",
                  "description": "Attacker intercepts and modifies data flowing between user devices and the AP\n",
                  "mitigation": "Enable WPA3 encryption, use end-to-end TLS for all communications",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 9,
                  "score": ""
                },
                {
                  "id": "bf61f543-8c53-4260-a3d9-e54847c1f32f",
                  "title": "Sniffing / Information Disclosure",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Information disclosure",
                  "description": "Attacker captures unencrypted wireless traffic to steal passwords and sensitive data",
                  "mitigation": "Mitigations: Enable WPA3 encryption, enforce VPN use for all wireless clients",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 10,
                  "score": ""
                },
                {
                  "id": "6ffe6edb-ffb5-47f3-b05c-fb354df288f8",
                  "title": "Unauthorised Network Access",
                  "status": "Mitigated",
                  "severity": "High",
                  "type": "Elevation of privilege",
                  "description": "Attacker gains unauthorised access to the network by exploiting weak or default credentials\n",
                  "mitigation": "Implement MFA and 802.1X port-based authentication, disable default credentials",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 11,
                  "score": ""
                },
                {
                  "id": "126f59d3-be9d-47db-bd5f-948a3104a0a3",
                  "title": "No Audit Trail / Repudiation",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "type": "Repudiation",
                  "description": " Lack of logging on the AP means attackers can deny their actions leaving no evidence of intrusion\n",
                  "mitigation": "Enable logging on the AP and file server, forward logs to a central SIEM",
                  "modelType": "STRIDE",
                  "new": false,
                  "number": 12,
                  "score": ""
                }
              ],
